MOLINFO STRUCTURE=reference.pdb
rmsd: RMSD REFERENCE=reference.pdb TYPE=OPTIMAL NOPBC
rg: GYRATION TYPE=RADIUS ATOMS=1-479
metad: METAD ARG=rmsd,rg SIGMA=0.05,0.05 HEIGHT=1.2 PACE=500 BIASFACTOR=12 TEMP=298.0 GRID_MIN=0.0,0.5 GRID_MAX=8.0,6.0 GRID_BIN=400,275 WALKERS_MPI GRID_WFILE=GRID.dat GRID_WSTRIDE=500000 CALC_RCT
PRINT ARG=rmsd,rg,metad.bias,metad.rbias,metad.rct STRIDE=5000 FILE=COLVAR
FLUSH STRIDE=500000
