calibration/*/
learn/bones/old_extractions/
learn/runs/

# MOPAC/APBS solver output
*.mc

# Smoke test output (timestamped runs + blessed baselines are machine-local)
tests/golden/smoke/
tests/golden/blessed/

# Build artifacts (CMake fetch)
_deps/
CTestTestfile.cmake
.qt/

# HighFive: only include/ is needed; ignore the rest of the upstream tree
extern/HighFive/CMake/
extern/HighFive/CMakeLists.txt
extern/HighFive/CHANGELOG.md
extern/HighFive/README.md
extern/HighFive/codecov.yml
extern/HighFive/doc/
extern/HighFive/src/
extern/HighFive/tests/
extern/HighFive/deps/
extern/HighFive/.*

# gemmi: only include/ is needed (header-only path). Anything else
# from a future upstream sync stays gitignored.
extern/gemmi/CMakeLists.txt
extern/gemmi/CMake/
extern/gemmi/cmake/
extern/gemmi/src/
extern/gemmi/tests/
extern/gemmi/docs/
extern/gemmi/.*

# Analysis outputs (regenerable from scripts)
learn/src/output/

# Stale git backup
.git-old/

# Claude Code per-session metadata (worktrees, shell history) — machine-local.
.claude/

# Analysis H5 fixtures — regenerable via nmr_extract --trajectory --analysis;
# individual files are 1-3 GB, total ~42 GB. Will not fit on GitHub.
fileformat/test/**/*.h5

# Salvaged artifact area from older builds — ELF binaries, moc
# generated files, CMakeCache, .mc solver output. Kept on disk for
# reference, not committed. Checked-in binaries go stale the moment
# they're pushed, and moc/CMake artifacts are regenerable noise.
bad-builds/

# Large test fixtures — MD trajectories (md.xtc ~18 MB each,
# 5 walkers), PLUMED grids (110K lines each), reference PDBs.
# Total ~295 MB. Regenerable from initial-samples/ via the fleet
# pipeline; machine-local, not repo material.
tests/data/fleet_test_large/

# Chemical Component Dictionary — 376 MB raw / 89 MB gzipped.
# Used by CcdValidator (gemmi header-only) to enrich IUPAC topology
# diagnostics. components.cif is the runtime file; .gz is kept as a
# refresh artifact. Both regenerable via scripts/fetch_ccd.sh.
data/ccd/components.cif
data/ccd/components.cif.gz

# Reference-corpus derived files — trivially regenerable from
# references/*.pdf via scripts/references/ingest_pdf.sh. At ~500
# papers these would add ~2 GB. Source-of-truth is the PDFs plus
# the distilled summaries and keywords in references-meta/ (both
# committed). See scripts/references/README.md.
references-text/
references-images/
